{
  "name": "<%= ctx.packageName %>",
  "version": "1.0.0",
  "description": "Create a new project - npm create <%= ctx.packageName.slice('create-'.length) %>",
  "scripts": {
    "prepare": "lefthook install",
    <%_ if (codeLinter === 'biome') { _%>
    "lint": "biome check && tsc --noEmit",
    "lint:fix": "biome check --fix --unsafe && tsc --noEmit",
    <%_ } else if (codeLinter === 'eslint') { _%>
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    <%_ } _%>
    "build": "NODE_ENV=production vite build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "bin": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": ["dist", "templates"],
  "keywords": ["create-creator"],
  "dependencies": {
    "create-creator": "^2.0.0"
  },
  "devDependencies": {
    <%_ if (codeLinter === 'biome') { _%>
    "@biomejs/biome": "1.9.4",
    <%_ } else if (codeLinter === 'eslint') { _%>
    "@antfu/eslint-config": "^3.14.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    <%_ } _%>
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@commitlint/types": "^19.5.0",
    "@types/node": "^<%= nodeVersion _%>",
    "@vitest/coverage-v8": "^3.0.2",
    "lefthook": "^1.10.10",
    "typescript": "^5.7.3",
    "vite": "^6.0.10",
    "vite-plugin-dts": "^4.5.0",
    "vite-plugin-externalize-deps": "^0.9.0",
    "vitest": "^3.0.2"
  }
}
